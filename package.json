{
  "name": "rebot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "rebot": "./dist/rebot.js"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "dev": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --target=bun --outfile dist/rebot.js && chmod +x dist/rebot.js",
    "build:binary": "bun build src/cli.ts --compile --outfile rebot"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.48",
    "ai": "^6.0.197",
    "commander": "^15.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/json-schema": "^7.0.15",
    "typescript": "latest"
  }
}
